  <script>
  (function() {
    const filterText = document.getElementById('filter-text');
    const filterSource = document.getElementById('filter-source');
    const filterMin = document.getElementById('filter-min');
    const count = document.getElementById('filter-count');
    const items = Array.from(document.querySelectorAll('article.item, .more-items li'));
  
    function apply() {
      const needle = (filterText.value || '').toLowerCase();
      const source = filterSource.value;
      const minScore = parseInt(filterMin.value, 10) || 0;
      let visible = 0;
      items.forEach(el => {
        const score = parseInt(el.dataset.score, 10) || 0;
        const src = el.dataset.source;
        const text = (el.textContent || '').toLowerCase();
        const ok = (!needle || text.indexOf(needle) >= 0)
                && (!source || src === source)
                && (score >= minScore);
        el.style.display = ok ? '' : 'none';
        if (ok) visible += 1;
      });
      count.textContent = visible + ' visible';
    }
  
    filterText.addEventListener('input', apply);
    filterSource.addEventListener('change', apply);
    filterMin.addEventListener('input', apply);
    apply();
  })();
  </script>
  
  </body>
