# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# Environment
.env

# uv
.uv-cache/

# Testing
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Per-build ephemera (state/seen.json is tracked)
state/.lock
state/run/

# Local sandbox
*.bak

# Override global .claude/ ignore — for this project the build-edition skill
# IS the product, so it must be committed.
!.claude/
!.claude/**

# Runtime lock state from scheduled-wakeup tooling, not editorial content.
.claude/scheduled_tasks.lock
