<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="cache-control" content="max-age=300">
  <title>{{ view.title }}</title>
  <link rel="stylesheet" href="assets/styles.css">
</head>
<body>

<header class="site-header">
  <div>
    <h1>{{ view.title }}</h1>
    <p class="subtitle">{{ view.subtitle }}</p>
  </div>
  <nav class="site-nav" aria-label="Audience views">
    <a href="index.html" {% if view.audience == 'general' %}class="current"{% endif %}>General</a>
    <a href="for-prathamesh.html" {% if view.audience == 'prathamesh' %}class="current"{% endif %}>Strategy</a>
    <a href="for-dl-team.html" {% if view.audience == 'dl_team' %}class="current"{% endif %}>Research</a>
    <a href="about.html">About</a>
  </nav>
  <span class="built-at">Built {{ built_at_human }}</span>
</header>

{% if not audit_passed %}
<div class="partial-banner">
  <strong>Partial build.</strong> This edition was published with at least one
  pre-publish check failed. See <a href="about.html">about</a> for details.
</div>
{% endif %}

{% if trend_bullets %}
<section class="brief" aria-label="Today's brief">
  <h2>Patterns this build</h2>
  <ul>
    {% for bullet in trend_bullets %}
    <li>{{ bullet.summary }}</li>
    {% endfor %}
  </ul>
</section>
{% endif %}

<section class="axes" aria-label="Items by axis">
  {% for axis_key, axis_label in axis_columns %}
  <div class="axis-col">
    <h2>{{ axis_label }}</h2>
    {% set col_items = items_by_axis.get(axis_key, []) %}
    {% if col_items %}
      {% for item in col_items %}
        {% include "partials/item_card.html.j2" %}
      {% endfor %}
    {% else %}
      <p class="item-summary">No items this build.</p>
    {% endif %}
  </div>
  {% endfor %}
</section>

{% if ai_partner_questions %}
<aside class="ai-partner" aria-label="Questions from your AI partner">
  <h2>Questions for the team</h2>
  <p class="ai-partner-howto">
    Append answers in
    <a href="{{ questions_file_url }}" target="_blank" rel="noopener">state/questions_for_team.md</a>
    (the agent reads it each build). For permanent rule changes, edit
    <a href="{{ context_file_url }}" target="_blank" rel="noopener">data/nanonets_context.md</a>.
  </p>
  {% for q in ai_partner_questions %}
  <div class="question">
    <p class="question-text">{{ q.question }}</p>
    <p class="question-context">{{ q.context }}</p>
    <p class="question-reply"><a href="{{ questions_edit_url }}" target="_blank" rel="noopener">Reply on GitHub →</a></p>
  </div>
  {% endfor %}
</aside>
{% endif %}

<footer class="site-footer">
  <p class="disclaimer">
    Auto-generated by Claude Code agents on a 6-hour cron. Editorial framing
    is not staff-reviewed and does not represent a Nanonets-corporate
    statement.
  </p>
  <p class="provenance">
    sources covered: {{ sources_covered|join(', ') }}{% if sources_failed %}
    · failed: {{ sources_failed|length }}{% endif %} · built at {{ built_at_iso }}
    · <a href="about.html">about</a>
  </p>
</footer>

</body>
</html>
