{% set ax = item.axis_scores %}
<article class="item {% if item.hostility_flag %}hostility{% endif %}"
         data-source="{{ item.source }}"
         data-score="{{ item.composite_score|round|int }}">
  <div class="item-meta">
    <span class="item-score"
          title="{% if ax %}doc_ai {{ ax.doc_ai }} · competitive {{ ax.competitive }} · frontier {{ ax.frontier }} · vlm_research {{ ax.vlm_research }} = {{ item.composite_score|round|int }} (this view's weighting){% else %}composite {{ item.composite_score|round|int }}{% endif %}">{{ item.composite_score|round|int }}</span>
    {% if ax %}
    <span class="sparkline" aria-hidden="true">
      <span style="height: {{ (ax.doc_ai * 20)|int }}%"></span><span style="height: {{ (ax.competitive * 20)|int }}%"></span><span style="height: {{ (ax.frontier * 20)|int }}%"></span><span style="height: {{ (ax.vlm_research * 20)|int }}%"></span>
    </span>
    {% endif %}
    <span class="item-source">{{ item.source }}</span>
    {% if item.source_count > 1 %}<span>×{{ item.source_count }}</span>{% endif %}
    {% if item.hostility_flag %}<span title="competitor commentary; descriptive framing">⚐</span>{% endif %}
  </div>
  <p class="item-title">
    <a href="{{ item.canonical_url }}" target="_blank" rel="nofollow noopener noreferrer">{{ item.title }}</a>
  </p>
  {% if item.one_line_summary %}
  <p class="item-summary">{{ item.one_line_summary }}</p>
  {% endif %}
  {% if item.framing %}
  <div class="framing">
    <dl>
      <dt>Product</dt>
      <dd>{{ item.framing.product_implication }}</dd>
      <dt>Research</dt>
      <dd>{{ item.framing.research_implication }}</dd>
      <dt>Action</dt>
      <dd>{{ item.framing.action_recommendation }}</dd>
    </dl>
  </div>
  {% endif %}
  {% if item.secondary_axes %}
  <p class="secondary-axes">also: {{ item.secondary_axes|join(', ') }}</p>
  {% endif %}
</article>
